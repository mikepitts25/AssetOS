# Supabase project URL — found in Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY. Never expose to the client.
# Used by the seed script and privileged server actions.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of the app (used for redirects, QR links, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret for the optional /api/cron/expire-stale manual trigger
# (`Authorization: Bearer <CRON_SECRET>`). Scheduling is handled by the
# in-database pg_cron job, so this is only needed if you call the route by hand
# or wire it to an external scheduler.
CRON_SECRET=

